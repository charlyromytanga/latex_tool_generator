.PHONY: test coverage lint format type clean help install-test

help:
	@echo "Test targets:"
	@echo "  make test              - Run unit tests"
	@echo "  make coverage          - Run tests with coverage report"
	@echo "  make lint              - Run code linting"
	@echo "  make format            - Format code with black and isort"
	@echo "  make type              - Run type checking with mypy"
	@echo "  make clean             - Clean test artifacts and cache"
	@echo "  make install-test      - Install test dependencies"

install-test:
	@echo "Installing test dependencies..."
	pip install -r requirements-test.txt

test:
	@echo "Running unit tests..."
	pytest tests/src_test -v

test-fast:
	@echo "Running unit tests without verbose output..."
	pytest tests/src_test

test-specific:
	@echo "Run specific test with: make test-file FILE=tests/src_test/app/test_api.py"
	@[ -z "$(FILE)" ] && echo "Error: FILE not specified" || pytest $(FILE) -v

coverage:
	@echo "Running tests with coverage report..."
	pytest tests/src_test \
		--cov=src \
		--cov-report=html \
		--cov-report=term-missing \
		--cov-report=xml
	@echo "Coverage report generated in htmlcov/index.html"

coverage-view:
	@echo "Opening coverage report..."
	open htmlcov/index.html || xdg-open htmlcov/index.html || start htmlcov/index.html

lint:
	@echo "Running code quality checks..."
	pylint src/ --exit-zero
	black --check src/ tests/
	isort --check-only src/ tests/

format:
	@echo "Formatting code..."
	black src/ tests/
	isort src/ tests/

type:
	@echo "Running type checking..."
	mypy src/ --ignore-missing-imports

clean:
	@echo "Cleaning test artifacts..."
	find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
	find . -type d -name .pytest_cache -exec rm -rf {} + 2>/dev/null || true
	find . -type d -name .mypy_cache -exec rm -rf {} + 2>/dev/null || true
	find . -type d -name htmlcov -exec rm -rf {} + 2>/dev/null || true
	find . -type f -name ".coverage*" -delete
	find . -type f -name "coverage.xml" -delete
	rm -rf .tox/
	@echo "Cleanup complete"

ci: clean install-test lint type coverage
	@echo "CI pipeline complete"

# Continuous testing (requires pytest-watch)
watch:
	ptw tests/src_test -- -v

# Integration tests marker
test-integration:
	@echo "Running integration tests..."
	pytest tests/src_test -m integration -v

# By module/feature
test-api:
	@echo "Testing API module..."
	pytest tests/src_test/app/ -v

test-streamlit:
	@echo "Testing Streamlit module..."
	pytest tests/src_test/app/streamlit/ -v

test-orchestration:
	@echo "Testing Orchestration module..."
	pytest tests/src_test/orchestration/ -v

test-channels:
	@echo "Testing Channels module..."
	pytest tests/src_test/channels/ -v

test-cvrepo:
	@echo "Testing CVRepo module..."
	pytest tests/src_test/cvrepo/ -v
