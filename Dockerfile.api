# Dockerfile pour le service API (FastAPI)
FROM python:3.10-slim

WORKDIR /app

COPY pyproject.toml ./
RUN pip install uv && uv sync -G api

COPY src/ ./src/
COPY db/ ./db/

# CMD à adapter selon ton entrypoint FastAPI
# CMD ["uvicorn", "src.api_gateway.main:app", "--host", "0.0.0.0", "--port", "8000"]
