# Environment variables for local development
# Copy to .env and update with actual values

# Database
DATABASE_URL=sqlite:///db/recruitment_assistant.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
API_RELOAD=true

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=false

# LLM Configuration
OPENAI_API_KEY=<your_openai_api_key>
OLLAMA_BASE_URL=http://localhost:11434

# LLM Settings
LLM_MODEL_EXTRACTION=gpt-4-turbo
LLM_MODEL_MATCHING=gpt-4-turbo
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Matching Configuration
CONFIDENCE_THRESHOLD_SKIP=0.5
CONFIDENCE_THRESHOLD_REVIEW=0.75
CONFIDENCE_THRESHOLD_GO=0.85

# GitHub Integration (for project reports)
GITHUB_TOKEN=ghp_
GITHUB_USERNAME=your_username

# Render Configuration (for production)
RENDER_SERVICE_ID_API=srv-
RENDER_SERVICE_ID_APP=srv-
RENDER_API_KEY=rnd_
RENDER_SERVICE_URL_API=https://api.yourapp.onrender.com
RENDER_SERVICE_URL_APP=https://app.yourapp.onrender.com

# Slack Notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/

# Email Configuration (for thank-you letters)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=your-email@gmail.com
SMTP_PASSWORD=app-specific-password

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Debug Mode
DEBUG=false
