# Configuration des variables d'environnement pour latex_tool_generator

# Clé API OpenAI (remplace par ta vraie clé)

# URL de la base de données (exemple pour SQLite)
DATABASE_URL=sqlite:///db/latex_tool.db

# Autres variables utiles
API_URL=http://localhost:8000

# Chemin base SQLite de recrutement (optionnel)
RECRUITMENT_DB_PATH=db/recruitment_assistant.db

# Chemin schéma SQLite (optionnel)
RECRUITMENT_SCHEMA_PATH=db/schema_init.sql

# Chemin schéma Postgres (optionnel)
RECRUITMENT_POSTGRES_SCHEMA_PATH=db/schema_postgres.sql

# Langue par défaut
DEFAULT_LANGUAGE=fr

# Seuils de matching
MATCH_REVIEW_THRESHOLD=0.5
MATCH_GO_THRESHOLD=0.75

# Version du modèle LLM
LLM_MODEL_VERSION=heuristic-v0
