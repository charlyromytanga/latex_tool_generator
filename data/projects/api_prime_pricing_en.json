{
  "language": "en",
  "project_id": "api_prime_pricing",
  "repo_name": "api_prime_pricing",
  "title": "API Prime Pricing",
  "description": "Auto insurance premium prediction project based on two ML models (frequency and severity), exposed via a FastAPI API and a Streamlit app.",
  "ats_bullet_en": "- Developed a FastAPI API and Streamlit app for auto insurance premium prediction using ML models (frequency, severity).",
  "stack": [
    "Python 3.11+",
    "FastAPI",
    "Streamlit",
    "scikit-learn",
    "pandas",
    "uv",
    "SQLite",
    "Docker",
    "GitHub Actions"
  ],
  "main_features": [
    "FastAPI API for ML inference (frequency, severity, premium)",
    "Streamlit app for user simulation",
    "ML models exported and used in inference",
    "Local SQLite database",
    "Automated CI/CD with GitHub Actions and Render"
  ],
  "folders": {
    "src/app/": "Main Streamlit app",
    "src/api/backend/": "FastAPI API",
    "src/models/": "ML pipeline and scripts",
    "output_models/modeles/": "Model JSON artifacts",
    "db/": "Local SQLite database"
  },
  "prod_urls": {
    "api": "https://api-prime-pricing.onrender.com",
    "app": "https://api-prime-pricing-app-cas.onrender.com"
  },
  "api_endpoints": [
    "GET /",
    "GET /health",
    "GET /predictio_frequence/health",
    "GET /predictio_severite/health",
    "POST /predict_frequence",
    "POST /predict_severite",
    "POST /predict_price",
    "GET /contrats?limit=20",
    "GET /contrats/{id_contrat}",
    "POST /contrats",
    "PUT /contrats/{id_contrat}",
    "GET /docs (OpenAPI)"
  ],
  "install": [
    "uv venv",
    "source .venv/bin/activate",
    "uv pip install -r requirements.txt"
  ],
  "run": [
    "uvicorn src.api.backend.server:app --host 0.0.0.0 --port 8000",
    "streamlit run src/app/app.py --server.address=0.0.0.0 --server.port=8501"
  ],
  "quality": [
    "bash lint_and_typecheck.sh"
  ],
  "test": [
    "pytest"
  ],
  "ci_cd": {
    "ci": [
      "Format/lint: black, ruff, flake8, pylint",
      "Tests: pytest",
      "Docker validation: build + endpoint smoke test"
    ],
    "cd": [
      "Automatic trigger if CI is success on main",
      "Call both Render deploy hooks: api_prime_pricing, api_prime_pricing_app"
    ]
  },
  "contributors": [
    "charlyromytanga",
    "DiamantNoire"
  ],
  "languages": {
    "Python": 96.8,
    "CSS": 2.8,
    "Other": 0.4
  }
}